.phpdocumentor-search {
    position: relative;
    display: none;
    opacity: 0.5;
    transition: opacity 0.2s ease;
    margin: 0;
    flex: 1;
    min-width: 0;
}

.phpdocumentor-search label {
    display: flex;
    align-items: center;
    flex: 1;
    background: var(--vp-c-bg-soft);
    border: 1px solid var(--vp-c-divider);
    border-radius: 10px;
    padding: 0.5rem 0.75rem;
    transition: var(--transition-theme), box-shadow 0.2s ease;
}

.phpdocumentor-search label:focus-within {
    border-color: var(--vp-c-brand-3);
    box-shadow: 0 0 0 3px var(--vp-c-brand-soft);
}

.phpdocumentor-search__icon {
    color: var(--vp-c-text-3);
    margin-right: var(--spacing-sm);
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
}

.phpdocumentor-search--enabled {
    display: flex;
}

.phpdocumentor-search--active {
    opacity: 1;
}

.phpdocumentor-search input:disabled {
    background-color: transparent;
}

.phpdocumentor-search__field:focus,
.phpdocumentor-search__field {
    margin-bottom: 0;
    border: 0;
    background: transparent;
    padding: 0;
    border-radius: 0;
    flex: 1;
    font-size: 0.875rem;
    color: var(--vp-c-text-1);
    box-shadow: none;
}

.phpdocumentor-search__field::placeholder {
    color: var(--vp-c-text-3);
}

@media (min-width: {{ breakpoints['menu'] }}) {
    .phpdocumentor-search {
        min-width: 10rem;
        max-width: 15rem;
    }
}