/* DLStorage — Ultra-modern documentation theme */

*,
*::before,
*::after {
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    background-color: var(--vp-c-bg);
    color: var(--vp-c-text-1);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition: var(--transition-theme);
}

.phpdocumentor {
    max-width: var(--container-width);
    margin: 0 auto;
}

.phpdocumentor-section {
    padding: 0 var(--spacing-lg);
}

/* ── Header ─────────────────────────────────────────────── */

.phpdocumentor-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--header-bg-color);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--vp-c-divider);
    box-shadow: var(--vp-c-shadow-1);
    transition: var(--transition-theme);
}

.dlstorage-header-actions {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-left: auto;
    flex: 1;
    justify-content: flex-end;
    min-width: 0;
}

.dlstorage-header-actions .phpdocumentor-search {
    margin: 0;
    flex: 1;
    max-width: 15rem;
    min-width: 0;
}

/* Theme toggle */
.dlstorage-theme-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid var(--vp-c-divider);
    border-radius: 10px;
    background: var(--vp-c-bg-soft);
    color: var(--vp-c-text-2);
    cursor: pointer;
    flex-shrink: 0;
    overflow: hidden;
    transition: var(--transition-theme), transform 0.2s ease;
}

.dlstorage-theme-toggle:hover {
    color: var(--vp-c-brand-1);
    border-color: rgba(100, 108, 255, 0.35);
    background: var(--vp-c-brand-soft);
    transform: translateY(-1px);
}

.dlstorage-theme-toggle:focus-visible {
    outline: 2px solid var(--vp-c-brand-3);
    outline-offset: 2px;
}

.dlstorage-theme-toggle__icon {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease, transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.dlstorage-theme-toggle__icon--light {
    opacity: 1;
    transform: rotate(0deg) scale(1);
}

.dlstorage-theme-toggle__icon--dark {
    opacity: 0;
    transform: rotate(-90deg) scale(0.6);
}

[data-theme="dark"] .dlstorage-theme-toggle__icon--light {
    opacity: 0;
    transform: rotate(90deg) scale(0.6);
}

[data-theme="dark"] .dlstorage-theme-toggle__icon--dark {
    opacity: 1;
    transform: rotate(0deg) scale(1);
}

/* ── Layout ─────────────────────────────────────────────── */

.phpdocumentor-sidebar {
    padding-top: var(--spacing-lg);
    padding-bottom: var(--spacing-xxl);
}

.phpdocumentor-content {
    padding: var(--spacing-xl) 0 var(--spacing-xxl);
    min-width: 0;
}

.phpdocumentor-content > section:first-of-type {
    max-width: 768px;
}

/* ── Typography ─────────────────────────────────────────── */

.phpdocumentor h1,
.phpdocumentor h2,
.phpdocumentor h3,
.phpdocumentor h4 {
    color: var(--vp-c-text-1);
    font-weight: 600;
    letter-spacing: -0.025em;
    transition: color 0.25s ease;
}

.phpdocumentor h1 {
    font-size: 2rem;
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
}

.phpdocumentor h2 {
    font-size: 1.5rem;
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid var(--vp-c-divider);
    margin-top: 2.75rem;
}

.phpdocumentor h3 {
    font-size: 1.2rem;
}

.phpdocumentor a {
    color: var(--vp-c-brand-1);
    text-decoration: none;
    transition: color 0.2s ease;
}

.phpdocumentor a:hover {
    color: var(--vp-c-brand-2);
}

.phpdocumentor-summary {
    font-style: normal;
    color: var(--vp-c-text-2);
    font-size: 1.0625rem;
    line-height: 1.65;
    margin-bottom: var(--spacing-lg);
}

.phpdocumentor-description {
    color: var(--vp-c-text-2);
}

/* ── API elements ───────────────────────────────────────── */

.phpdocumentor-element .phpdocumentor-element {
    border: 1px solid var(--vp-c-divider);
    border-radius: var(--border-radius-base-size);
    background: var(--vp-c-bg-elevated);
    box-shadow: var(--vp-c-shadow-1);
    transition: var(--transition-theme), transform 0.2s ease;
}

.phpdocumentor-element .phpdocumentor-element:hover {
    border-color: rgba(100, 108, 255, 0.4);
    box-shadow: var(--vp-c-shadow-2);
}

.phpdocumentor .phpdocumentor-element__name {
    font-weight: 600;
    color: var(--vp-c-text-1);
    word-break: break-word;
}

.phpdocumentor-element__modifier {
    background: var(--vp-c-brand-soft);
    color: var(--vp-c-brand-1);
    font-weight: 600;
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    border-radius: 6px;
}

.phpdocumentor .phpdocumentor-signature {
    border: 1px solid var(--vp-c-divider);
    border-radius: var(--border-radius-base-size);
    background: var(--vp-c-bg-soft);
    padding: var(--spacing-sm) var(--spacing-md);
    margin-left: 0 !important;
    width: 100% !important;
    transition: var(--transition-theme);
}

.phpdocumentor-code,
.phpdocumentor pre {
    border-radius: var(--border-radius-base-size);
}

.phpdocumentor-code {
    font-size: 0.875em;
}

/* ── Nav & TOC ──────────────────────────────────────────── */

.phpdocumentor-table-of-contents .phpdocumentor-table-of-contents__entry > a {
    color: var(--vp-c-text-2);
    font-size: 0.9375rem;
    padding: 0.125rem 0;
    transition: color 0.15s ease;
}

.phpdocumentor-table-of-contents .phpdocumentor-table-of-contents__entry > a:hover {
    color: var(--vp-c-brand-1);
}

.phpdocumentor-breadcrumbs {
    color: var(--vp-c-text-3);
    font-size: 0.875rem;
}

.phpdocumentor-tag-list__heading {
    color: var(--vp-c-text-3);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
}

.phpdocumentor-on-this-page__sidebar {
    font-size: 0.8125rem;
}

/* ── Hero & cards ───────────────────────────────────────── */

.dlstorage-hero {
    position: relative;
    margin-bottom: var(--spacing-xxl);
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    overflow: hidden;
}

.dlstorage-hero::before {
    content: '';
    position: absolute;
    inset: -40% -20% auto -20%;
    height: 280px;
    background:
        radial-gradient(ellipse 60% 50% at 20% 40%, var(--vp-c-glow), transparent 70%),
        radial-gradient(ellipse 50% 40% at 80% 20%, rgba(86, 114, 205, 0.12), transparent 65%);
    pointer-events: none;
    z-index: 0;
}

.dlstorage-hero > * {
    position: relative;
    z-index: 1;
}

.dlstorage-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--vp-c-brand-1);
    background: var(--vp-c-brand-soft);
    border: 1px solid rgba(100, 108, 255, 0.2);
    border-radius: 999px;
    margin-bottom: var(--spacing-md);
}

.dlstorage-hero__title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0 0 var(--spacing-sm);
    color: var(--vp-c-text-1);
    background: linear-gradient(135deg, var(--vp-c-text-1) 30%, var(--vp-c-brand-1) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.dlstorage-hero__subtitle {
    font-size: 1.125rem;
    color: var(--vp-c-text-2);
    line-height: 1.65;
    max-width: 38rem;
    margin: 0 0 var(--spacing-xl);
}

.dlstorage-hero__subtitle code {
    font-size: 0.9em;
    padding: 0.15em 0.45em;
    background: var(--vp-c-bg-soft);
    border: 1px solid var(--vp-c-divider);
    border-radius: 6px;
    color: var(--vp-c-brand-1);
}

.dlstorage-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xxl);
}

.dlstorage-card {
    display: block;
    padding: var(--spacing-lg);
    border: 1px solid var(--vp-c-divider);
    border-radius: 12px;
    background: var(--vp-c-bg-elevated);
    text-decoration: none;
    color: inherit;
    transition: var(--transition-theme), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s ease;
}

.dlstorage-card:hover {
    border-color: rgba(100, 108, 255, 0.45);
    transform: translateY(-3px);
    box-shadow: var(--vp-c-shadow-3);
    color: inherit;
}

.dlstorage-card__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--vp-c-text-1);
    margin: 0 0 var(--spacing-xs);
}

.dlstorage-card__desc {
    font-size: 0.875rem;
    color: var(--vp-c-text-3);
    margin: 0;
    line-height: 1.55;
}

.dlstorage-version-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--vp-c-text-3);
    background: var(--vp-c-bg-mute);
    border: 1px solid var(--vp-c-divider);
    border-radius: 999px;
    margin-left: var(--spacing-sm);
    vertical-align: middle;
}

/* ── Code blocks ────────────────────────────────────────── */

pre[class*="language-"],
code[class*="language-"] {
    font-family: var(--font-monospace) !important;
    font-size: 0.875em !important;
    text-shadow: none !important;
    transition: background 0.25s ease, color 0.25s ease;
}

[data-theme="dark"] pre[class*="language-"],
[data-theme="dark"] code[class*="language-"] {
    background: var(--vp-c-bg-mute) !important;
    color: var(--vp-c-text-1) !important;
}

/* ── Search results ─────────────────────────────────────── */

.phpdocumentor-search-results {
    background: var(--popover-background-color);
    border: 1px solid var(--vp-c-divider);
    border-radius: 12px;
    box-shadow: var(--vp-c-shadow-2);
    backdrop-filter: blur(16px);
}

/* ── Responsive ─────────────────────────────────────────── */

@media (max-width: 768px) {
    .dlstorage-header-actions {
        width: 100%;
        order: 3;
    }

    .dlstorage-header-actions .phpdocumentor-search {
        max-width: none;
    }

    .phpdocumentor-section {
        padding: 0 var(--spacing-md);
    }
}

@media (min-width: {{ breakpoints['menu'] }}) {
    .dlstorage-header-actions {
        flex: 0 1 auto;
        width: auto;
    }
}