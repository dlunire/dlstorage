.phpdocumentor h1,
.phpdocumentor h2,
.phpdocumentor h3,
.phpdocumentor h4,
.phpdocumentor h5,
.phpdocumentor h6 {
    margin-bottom: var(--spacing-md);
    margin-top: var(--spacing-xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--vp-c-text-1);
}

.phpdocumentor h1 {
    font-size: 2rem;
    line-height: 1.25;
    margin-top: 0;
}

.phpdocumentor h2 {
    font-size: 1.5rem;
    line-height: 1.3;
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid var(--vp-c-divider);
}

.phpdocumentor h3 {
    font-size: 1.25rem;
    line-height: 1.35;
}

.phpdocumentor h4 {
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
    line-height: 1.4;
    margin-bottom: var(--spacing-sm);
}

.phpdocumentor h5 {
    font-size: 1rem;
    line-height: 1.5;
    margin-bottom: var(--spacing-sm);
    margin-top: var(--spacing-md);
}

.phpdocumentor h6 {
    font-size: 0.875rem;
    letter-spacing: 0;
    line-height: var(--line-height--primary);
    margin-bottom: var(--spacing-sm);
    margin-top: var(--spacing-md);
    color: var(--vp-c-text-2);
}